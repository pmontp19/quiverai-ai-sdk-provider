{
  "name": "quiverai-ai-provider",
  "version": "0.2.2",
  "description": "QuiverAI provider for the Vercel AI SDK — SVG generation via generateText, streamText, and generateImage",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test-d.ts",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.19"
  },
  "peerDependencies": {
    "zod": "^3.25.76 || ^4.1.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "quiverai",
    "svg",
    "vector",
    "image-generation"
  ],
  "homepage": "https://github.com/pmontp19/quiverai-ai-sdk-provider",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmontp19/quiverai-ai-sdk-provider.git"
  },
  "bugs": {
    "url": "https://github.com/pmontp19/quiverai-ai-sdk-provider/issues"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  }
}
