{
  "name": "quiverai-ai-provider",
  "version": "0.1.0",
  "description": "QuiverAI provider for the Vercel AI SDK — SVG generation via generateText, streamText, and generateImage",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test-d.ts",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {
    "@ai-sdk/provider": "^4.0.0-beta.0",
    "@ai-sdk/provider-utils": "^5.0.0-beta.1"
  },
  "peerDependencies": {
    "zod": "^3.25.76 || ^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "quiverai",
    "svg",
    "vector",
    "image-generation"
  ],
  "homepage": "https://github.com/pmontp19/quiverai-ai-provider",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmontp19/quiverai-ai-provider.git"
  },
  "bugs": {
    "url": "https://github.com/pmontp19/quiverai-ai-provider/issues"
  }
}
